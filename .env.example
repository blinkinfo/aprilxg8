# =============================================================================
# REQUIRED
# =============================================================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (get from /start command)
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# TRADING (Optional)
# =============================================================================

# Trading symbol (default: BTCUSDT)
TRADING_SYMBOL=BTCUSDT

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# MODEL SETTINGS (Optional)
# =============================================================================

# Minimum raw confidence threshold to emit a signal (default: 0.52)
# PREDICTION_THRESHOLD=0.52
# CONFIDENCE_MIN=0.52

# How often to retrain the model in hours (default: 6)
RETRAIN_INTERVAL_HOURS=6

# Number of recent candles used for live feature engineering (default: 100)
LOOKBACK_CANDLES=100

# Number of candles used for model training (~150 days of 5m data, default: 43200)
TRAIN_CANDLES=43200

# Optuna hyperparameter tuning (default: true)
ENABLE_OPTUNA=true
OPTUNA_TRIALS=40
OPTUNA_TIMEOUT=750

# =============================================================================
# v7: EV-BASED FILTERING (Optional)
# =============================================================================

# Min expected value to trade (0.0 = only positive EV trades)
# EV_THRESHOLD=0.0

# EV above this marks signal as STRONG (default: 0.05)
# EV_STRONG_THRESHOLD=0.05

# Profit on a winning trade ($)
# WIN_PAYOUT=0.96

# Loss on a losing trade ($)
# LOSS_AMOUNT=1.00

# =============================================================================
# v7: PROBABILITY CALIBRATION (Optional)
# =============================================================================

# Isotonic regression calibration on OOS split (default: true)
# ENABLE_CALIBRATION=true

# =============================================================================
# v7: FEATURE PRUNING (Optional)
# =============================================================================

# Prune low-importance features after training (default: true)
# ENABLE_FEATURE_PRUNING=true

# Keep top N features by importance (default: 20)
# FEATURE_PRUNE_TOP_N=20

# =============================================================================
# POLYMARKET TRADING (Optional)
# Set POLYMARKET_PRIVATE_KEY to enable Polymarket integration.
# Without it, the bot runs in signal-only mode -- no trades are placed.
# =============================================================================

# EVM private key of the wallet used to sign orders
POLYMARKET_PRIVATE_KEY=

# Funder/proxy wallet address (required if using a delegated Safe wallet)
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0 = EOA, 1 = EIP-1271, 2 = Gnosis Safe (default: 2)
POLYMARKET_SIGNATURE_TYPE=2

# =============================================================================
# POLYMARKET POSITION REDEMPTION (Optional)
# Automatically redeems resolved on-chain positions.
# Only active when POLYMARKET_PRIVATE_KEY is set.
# Requires the EOA wallet to hold a small amount of POL for gas (~0.005 POL).
# =============================================================================

# Polygon RPC endpoint used for on-chain redemption transactions.
# Defaults to the public RPC. Use a private Alchemy/Infura URL for reliability.
POLYGON_RPC_URL=https://polygon-rpc.com

# Enable or disable automatic redemption (default: true)
POLYMARKET_AUTO_REDEEM=true

# How often to scan for redeemable positions, in seconds (default: 120)
POLYMARKET_REDEEM_INTERVAL=120

# =============================================================================
# V5: MULTI-MODEL ENSEMBLE (Optional — defaults shown)
# =============================================================================

# Enable V5 ensemble (false = use V4 single XGBoost)
USE_V5_ENSEMBLE=true

# Training data window (~70 days of 5m data, fresher = better)
V5_TRAIN_CANDLES=20000

# Retrain interval (faster adaptation)
V5_RETRAIN_HOURS=2

# Optuna trials per model (3 models × 15 = 45 total)
V5_OPTUNA_TRIALS=15
V5_OPTUNA_TIMEOUT=300

# Feature pruning (per model)
V5_PRUNE_TOP_N=25

# Trade tiers
V5_TIER1_THRESHOLD=0.57
V5_TIER2_THRESHOLD=0.54
V5_TIER3_THRESHOLD=0.52
V5_TIER3_MIN_AGREEMENT=2

# Minimum OOS accuracy for model swap
V5_MIN_OOS_ACC=0.53

# Weight multiplier for recent training data
V5_RECENT_WEIGHT=3.0

